@model IEnumerable<AppPresupuestosSockets.Models.Presupuestos>
@{
    ViewData["Title"] = "Home";
}
<div class="mb-3">
    <a asp-controller="Presupuestos" asp-action="Index" class="btn btn-success shadow-sm">
        <i class="bi bi-plus-circle"></i> Nuevo Presupuesto
    </a>
    <a asp-controller="Usuarios" asp-action="Index" class="btn btn-success shadow-sm">
        <i class="bi bi-plus-circle"></i> Nuevo Usuario
    </a>
</div>
<div class="row my-4" style="max-height: 70vh; overflow-y: auto;"> 
    @foreach (var presupuesto in Model)
    {
        <div class="col-sm-6 mb-4"> <div class="card h-100 shadow-sm"> <div class="card-body d-flex flex-column">
                    <h5 class="card-title text-primary">@presupuesto.Nombre</h5>
                    
                    <div class="card-text flex-grow-1 mb-3">
                        @presupuesto.Descripcion
                    </div>

                    <div class="mt-auto"> <a asp-controller="Presupuestos" asp-action="VerDetalle" asp-route-id="@presupuesto.Id" class="btn btn-primary w-100">
                            Ir al presupuesto
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
